# ============================================================
# HeavyMetric — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# NUNCA commitees .env.local al repositorio
# ============================================================

# Supabase
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # solo para funciones server-side (api/)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=       # clave pública, segura en frontend

# Seguridad cron
CRON_SECRET=                  # generá con: openssl rand -hex 32

# APIs externas
VITE_ANTHROPIC_API_KEY=
VITE_RESEND_API_KEY=
