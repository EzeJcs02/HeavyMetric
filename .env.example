# ============================================================
# HeavyMetric — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# NUNCA commitees .env.local al repositorio
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # solo para funciones server-side (api/)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=       # clave pública, segura en frontend

# ── Seguridad ─────────────────────────────────────────────────
CRON_SECRET=                  # generá con: openssl rand -hex 32

# ── APIs externas (frontend) ──────────────────────────────────
VITE_ANTHROPIC_API_KEY=

# ── Feature Flags de Integraciones (Fase J) ───────────────────
# Cambiar a "true" para activar la integración real (requiere credenciales server-side)
VITE_ENABLE_ARCA=false
VITE_ENABLE_WHATSAPP=false
VITE_ENABLE_EMAIL=false
VITE_ENABLE_STORAGE=false
VITE_ENABLE_BANCOS=false
VITE_ENABLE_OCR=false

# ── ARCA / AFIP (server-side, sin VITE_) ─────────────────────
# Opción A: REST proxy (más simple)
ARCA_API_URL=                 # URL base del proveedor AFIP REST, ej: https://api.miproveedor.com/afip
ARCA_API_KEY=                 # Bearer token del proveedor (si lo requiere)
# Opción B: WSAA directo con certificado
ARCA_CERT=                    # Certificado p12 en base64 (openssl pkcs12 -export ...)
ARCA_CUIT=                    # CUIT de la organización para WSAA
ARCA_ENV=homo                 # "homo" para homologación, "prod" para producción

# ── WhatsApp Business (server-side) ──────────────────────────
# Obtener en: Meta Business Manager → WhatsApp → Getting Started
WHATSAPP_ACCESS_TOKEN=        # User o System User Access Token
WHATSAPP_PHONE_NUMBER_ID=     # ID del número de teléfono registrado en Meta

# ── Email — Resend (server-side) ──────────────────────────────
# Crear cuenta en resend.com y verificar el dominio
RESEND_API_KEY=               # clave de API de Resend (re_...)
RESEND_FROM=                  # ej: HeavyMetric <notificaciones@tudominio.com>

# ── OCR — Google Cloud Vision (server-side) ───────────────────
# Crear API Key en console.cloud.google.com con Cloud Vision API habilitada
GOOGLE_CLOUD_API_KEY=
